# =============================================================
#  FarmWise — .gitignore
#  Django backend + React/Vite frontend monorepo
# =============================================================

# ─── Python / Django ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# Virtual environments
venv/
env/
.venv/
.env/
ENV/

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
static_collected/

# Migrations (optional — keep if you want to commit them)
# backend/apps/*/migrations/

# Byte-compiled
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
MANIFEST

# ML model artifacts (if large; add back if small enough)
# backend/apps/crops/ml_models/*.pkl
# backend/apps/crops/ml_models/*.joblib

# ─── Node / React / Vite ────────────────────────────────────
node_modules/
frontend/node_modules/

# Vite build output
frontend/dist/
frontend/dist-ssr/
*.local

# Vite cache
frontend/.vite/

# ─── Environment Files ───────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env

# Keep the example file
!.env.example
!backend/.env.example

# ─── OS Files ────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ─── Editor / IDE ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.history/

# ─── Testing & Coverage ──────────────────────────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
nosetests.xml
test-results/

# ─── Misc ────────────────────────────────────────────────────
*.bak
*.tmp
*.orig
*.rej
.cache/
